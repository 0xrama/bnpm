{
  "name": "@0xrama/bnpm",
  "version": "0.0.1",
  "description": "A fast, security-focused npm-compatible package manager",
  "type": "module",
  "bin": {
    "bnpm": "dist/src/cli.js",
    "bnpmx": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "dist/package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=22.22.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "verify:package": "npm run build && node scripts/verify-package.mjs",
    "start": "node dist/src/cli.js"
  },
  "dependencies": {
    "npm-package-arg": "13.0.2",
    "node-gyp": "13.0.1",
    "npm-packlist": "11.3.0",
    "semver": "7.8.5",
    "sigstore": "5.0.0",
    "tar-stream": "3.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/npm-package-arg": "6.1.4",
    "@types/semver": "7.7.1",
    "@types/tar-stream": "3.1.4",
    "typescript": "^7.0.2"
  }
}
